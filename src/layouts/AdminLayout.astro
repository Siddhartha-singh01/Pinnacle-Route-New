---
import '@/styles/global.css';

interface Props {
  title: string;
  activeTab?: 'overview' | 'blog' | 'settings' | 'cms' | 'leads';
}

const { title, activeTab = 'overview' } = Astro.props;

const menuItems = [
  { id: 'overview', label: 'Overview', href: '/admin', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>' },
  { id: 'leads', label: 'Inquiries & Leads', href: '/admin/leads', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>' },
  { id: 'blog', label: 'Blog Posts', href: '/admin/blog', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>' },
  { id: 'cms', label: 'Frontend CMS', href: '/admin/cms', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>' },
  { id: 'settings', label: 'App Settings', href: '/admin/settings', icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pinnacle Route Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/brand/favicon-web.png" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="admin-panel-theme bg-[#ffffff] text-black antialiased flex h-screen overflow-hidden font-sans">
    <!-- Sidebar -->
    <aside class="w-64 border-r border-line-soft bg-ink flex flex-col shrink-0">
      <div class="h-16 flex items-center px-6 border-b border-line-soft">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
          <img src="/assets/brand/logo.png" alt="Logo" class="h-6" />
          <span class="text-xs font-bold tracking-widest text-gold uppercase mt-0.5">Admin</span>
        </a>
      </div>
      
      <nav class="flex-1 p-4 flex flex-col gap-1">
        {menuItems.map(item => (
          <a 
            href={item.href} 
            class={`flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeTab === item.id ? 'bg-surface border border-line-soft text-white' : 'text-grey-2 hover:text-white hover:bg-surface-2'}`}
          >
            <Fragment set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </nav>

      <div class="p-4 border-t border-line-soft flex flex-col gap-1">
        <a href="/admin/logout" data-astro-prefetch="false" class="flex items-center gap-3 px-4 py-2 text-sm text-grey-2 hover:text-white transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Logout Securely
        </a>
        <a href="/" class="flex items-center gap-3 px-4 py-2 text-sm text-grey-2 hover:text-white transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          Exit to Website
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col min-w-0 bg-[#fafafb]">
      <!-- Topbar -->
      <header class="h-16 border-b border-line-soft bg-ink/50 backdrop-blur flex items-center justify-between px-8 shrink-0 z-10">
        <div class="flex items-center gap-2 text-sm font-medium text-grey-2">
          <span class="text-white">Admin</span>
          <span>/</span>
          <span class="capitalize">{activeTab}</span>
        </div>
        
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-full bg-surface border border-line-soft flex items-center justify-center text-xs font-bold text-white">
            PR
          </div>
        </div>
      </header>

      <!-- Scrollable Area -->
      <main class="flex-1 overflow-y-auto p-8 relative">
        <slot />
      </main>
    </div>

    <style is:global>
      /* Light theme overrides for Pinnacle Route Admin Panel */
      .admin-panel-theme {
        --color-ink: #ffffff !important;
        --color-ink-2: #fafafb !important;
        --color-surface: #ffffff !important;
        --color-surface-2: #f4f4f5 !important;
        --color-line: rgba(10, 10, 10, 0.08) !important;
        --color-line-soft: rgba(10, 10, 10, 0.06) !important;
        
        /* Text color overrides */
        --color-white: #0a0a0c !important; /* Text that was text-white becomes black */
        --color-grey: #4b5563 !important;   /* Text that was grey becomes darker */
        --color-grey-2: #71717a !important; /* Text that was grey-2 becomes darker gray */
        --color-grey-3: #a1a1aa !important; /* Text that was grey-3 becomes medium gray */
      }

      /* Base layout overrides */
      body.admin-panel-theme,
      .admin-panel-theme a,
      .admin-panel-theme button,
      .admin-panel-theme select,
      .admin-panel-theme input,
      .admin-panel-theme textarea,
      .admin-panel-theme .cursor-pointer,
      .admin-panel-theme [role="button"] {
        cursor: auto !important;
      }

      body.admin-panel-theme {
        background-color: #fafafb !important;
        color: #0a0a0c !important;
      }

      /* Inputs, Textareas and Select fields */
      .admin-panel-theme input,
      .admin-panel-theme textarea,
      .admin-panel-theme select {
        background-color: #ffffff !important;
        color: #0a0a0c !important;
        border-color: rgba(10, 10, 10, 0.12) !important;
      }
      .admin-panel-theme input:focus,
      .admin-panel-theme textarea:focus,
      .admin-panel-theme select:focus {
        border-color: #c9a24b !important;
        outline: none !important;
      }
      .admin-panel-theme label {
        color: #4b5563 !important;
      }

      /* Sidebar & nav links styling overrides */
      aside.bg-ink {
        background-color: #ffffff !important;
      }
      aside a {
        color: #71717a !important;
      }
      aside a svg {
        color: #71717a !important;
      }
      aside a:hover {
        background-color: #f4f4f5 !important;
        color: #0a0a0c !important;
      }
      aside a:hover svg {
        color: #0a0a0c !important;
      }

      /* Topbar header logo & items */
      header .text-white {
        color: #0a0a0c !important;
      }
      header .text-grey-2 {
        color: #71717a !important;
      }

      /* Hardcoded background overrides for CMS elements & cards */
      .admin-panel-theme .bg-\[\#050505\],
      .admin-panel-theme .bg-\[\#0a0a0a\],
      .admin-panel-theme .bg-\[\#0f0f0f\],
      .admin-panel-theme .bg-\[\#111\],
      .admin-panel-theme .bg-\[\#111111\] {
        background-color: #ffffff !important;
        color: #0a0a0c !important;
        border-color: rgba(10, 10, 10, 0.08) !important;
      }

      /* Specific adjustment for CMS layout container */
      .admin-panel-theme .bg-\[\#0f0f0f\] {
        background-color: #f4f4f5 !important;
      }
      .admin-panel-theme .bg-\[\#0a0a0a\] {
        background-color: #ffffff !important;
      }

      /* General components overrides */
      .admin-panel-theme button.bg-white {
        background-color: #0a0a0c !important;
        color: #ffffff !important;
      }
      .admin-panel-theme button.bg-white:hover {
        background-color: #c9a24b !important;
        color: #ffffff !important;
      }

      /* Table overrides */
      .admin-panel-theme table th {
        background-color: #f4f4f5 !important;
        color: #4b5563 !important;
        border-bottom-color: rgba(10, 10, 10, 0.08) !important;
      }
      .admin-panel-theme table tr {
        border-bottom-color: rgba(10, 10, 10, 0.06) !important;
      }
      .admin-panel-theme table tr:hover {
        background-color: #f9f9fb !important;
      }

      /* SVGs & Icons color */
      .admin-panel-theme svg {
        stroke: currentColor !important;
      }

      /* Headings color */
      .admin-panel-theme h1,
      .admin-panel-theme h2,
      .admin-panel-theme h3,
      .admin-panel-theme h4,
      .admin-panel-theme h5,
      .admin-panel-theme h6 {
        color: #0a0a0c !important;
      }

      /* CMS Navigation lists and drag states */
      .admin-panel-theme .border-line-soft {
        border-color: rgba(10, 10, 10, 0.06) !important;
      }
    </style>
  </body>
</html>
