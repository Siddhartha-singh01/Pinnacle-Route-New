---
/**
 * Solutions Landing Page
 */
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import CtaBanner from "@/components/sections/CtaBanner.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";

import { db, SolutionDetails } from "astro:db";

const solutions = await db.select().from(SolutionDetails);
---

<BaseLayout
  title="Our Solutions · Pinnacle Route"
  description="Explore our specialized industry solutions."
  navTheme="light"
  strictNav={true}
>
  <section class="relative h-[65vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-ink">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-ink/80 mix-blend-multiply z-10"></div>
      <img
        src="/assets/solutions/ai-powered-sales-funnels.jpg"
        alt="Solutions"
        class="h-full w-full object-cover opacity-30 grayscale"
      />
    </div>
    
    <div class="container-page relative z-10 text-center">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Solutions" }]} tone="dark" class="mb-6 flex justify-center" />
      <h1 class="display-sm !text-[clamp(3rem,6vw,5rem)] text-white" data-reveal>
        Industry Solutions
      </h1>
      <p class="mt-4 text-grey max-w-xl mx-auto" data-reveal>
        Specialized platforms and tailored workflows engineered to accelerate growth and operational efficiency.
      </p>
    </div>
  </section>

  <section class="py-32 bg-paper text-ink">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {solutions.map((solution) => (
          <a href={`/solutions/${solution.slug}`} class="group relative bg-[#ffffff] rounded-3xl p-8 border border-line-soft hover:border-ink/20 transition-all duration-500 overflow-hidden flex flex-col h-full shadow-sm hover:shadow-xl">
            <div class="absolute inset-0 bg-[#faf7f0] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            
            <div class="relative z-10 flex-1">
              <span class="inline-block px-3 py-1 bg-ink/5 text-ink text-xs font-medium uppercase tracking-wider rounded-full mb-6">
                {solution.eyebrow}
              </span>
              
              <h3 class="text-2xl font-display font-medium mb-4 group-hover:text-[#CAA154] transition-colors">
                {solution.label}
              </h3>
              
              <p class="text-ink/70 leading-relaxed mb-8">
                {solution.tagline}
              </p>
            </div>
            
            <div class="relative z-10 mt-auto flex items-center justify-between pt-6 border-t border-line-soft group-hover:border-ink/10 transition-colors">
              <span class="text-sm font-medium">Explore Solution</span>
              <span class="w-10 h-10 rounded-full border border-line-soft flex items-center justify-center group-hover:bg-[#CAA154] group-hover:text-white group-hover:border-[#CAA154] transition-all duration-300">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    eyebrow="Let's talk"
    headline="We'd love to hear about"
    headlineDim="your project"
    links={[{ href: "/strategy-call", label: "Start a project", variant: "light" }]}
  />
</BaseLayout>
