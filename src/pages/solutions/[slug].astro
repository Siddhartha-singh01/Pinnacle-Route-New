---
/**
 * Solution detail page
 * --------------------
 * One template, prerendered per solution — but the layout varies per page
 * (hero / overview / features / process) so no two pages look alike.
 */
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArrowMotif from "@/components/ui/ArrowMotif.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
import ImageTextSplit from "@/components/sections/ImageTextSplit.astro";
import StatsRow from "@/components/sections/StatsRow.astro";
import CtaBanner from "@/components/sections/CtaBanner.astro";
import { solutionLayouts, defaultSolutionLayout } from "@/data/solution-details";
import type { SolutionDetail } from "@/types";
import { db, SolutionDetails, eq } from "astro:db";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const dbResult = await db.select().from(SolutionDetails).where(eq(SolutionDetails.slug, slug));
if (dbResult.length === 0) {
  return Astro.redirect('/404');
}

const rawSol = dbResult[0];
const sol: SolutionDetail = {
  slug: rawSol.slug,
  label: rawSol.label,
  eyebrow: rawSol.eyebrow,
  title: rawSol.title,
  titleDim: rawSol.titleDim,
  tagline: rawSol.tagline,
  image: rawSol.image,
  video: rawSol.video ?? undefined,
  overviewHeading: rawSol.overviewHeading,
  overviewHeadingDim: rawSol.overviewHeadingDim,
  overviewBody: rawSol.overviewBody,
  featuresHeading: rawSol.featuresHeading,
  features: rawSol.featuresJson as any,
  processHeading: rawSol.processHeading,
  steps: rawSol.stepsJson as any,
  stats: rawSol.statsJson as any,
  ctaHeadline: rawSol.ctaHeadline,
  ctaHeadlineDim: rawSol.ctaHeadlineDim,
};
const L = solutionLayouts[sol.slug] ?? defaultSolutionLayout;

// Precomputed light/dark classes for the features section.
const isLight = L.featuresLight;
const cardClass = isLight
  ? "rounded-[1.25rem] border border-ink/10 bg-paper-2 p-7 transition-transform duration-500 hover:-translate-y-1"
  : "rounded-[1.25rem] border border-line-soft bg-surface p-7 transition-transform duration-500 hover:-translate-y-1";
const iconWrap = isLight
  ? "grid place-items-center h-11 w-11 rounded-xl border border-ink/15 text-ink"
  : "grid place-items-center h-11 w-11 rounded-xl border border-line text-white";
const fTitle = isLight ? "text-ink" : "text-white";
const fDesc = isLight ? "text-ink/60" : "text-grey-2";
const rowBorder = isLight ? "border-ink/10" : "border-line-soft";

const ctas = [
  { href: "/strategy-call", label: "Book a strategy call", arrow: "→", variant: "light" },
  { href: "/#solutions", label: "All solutions", arrow: "↗", variant: "dark" },
];
---

<BaseLayout title={`${sol.label} · Pinnacle Route`} description={sol.tagline}>
  {/* ============================ HERO ============================ */}
  {
    L.hero === "split" ? (
      <section class="relative overflow-hidden pt-40 pb-20 lg:pt-44 lg:pb-28">
        <div class="container-page relative z-10 grid gap-12 lg:grid-cols-2">
          <div>
            <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Solutions", href: "/#solutions" }, { label: sol.label }]} tone="dark" class="mb-7" />
            <p class="eyebrow mb-7" data-reveal>{sol.eyebrow}</p>
            <h1 class="display-sm !text-[clamp(2.8rem,6vw,5rem)] max-w-[14ch]" data-reveal data-reveal-delay="1">
              {sol.title} <span class="dim">{sol.titleDim}</span>
            </h1>
            <p class="mt-7 max-w-md text-lg text-grey-2" data-reveal data-reveal-delay="2">{sol.tagline}</p>
            <div class="mt-9 flex flex-wrap gap-4" data-reveal data-reveal-delay="3">
              {ctas.map((c) => (
                <a href={c.href} class={`pill pill-${c.variant}`} data-magnetic="0.25">
                  {c.label} <span class="arrow">{c.arrow}</span>
                </a>
              ))}
            </div>
          </div>
          <div class="relative h-[350px] sm:h-[450px] lg:h-full lg:min-h-[520px]" data-reveal data-reveal-delay="2">
            <div class="absolute inset-0 overflow-hidden rounded-2xl border border-line-soft bg-ink/50">
              {sol.video ? (
                <video
                  class="absolute inset-0 h-full w-full object-cover"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster={sol.image}
                >
                  <source src={sol.video} type="video/mp4" />
                </video>
              ) : (
                <img src={sol.image} alt={sol.label} loading="lazy" decoding="async" data-parallax="0.06" class="absolute inset-0 h-[115%] w-full object-cover -top-[7%]" />
              )}
            </div>
          </div>
        </div>
      </section>
    ) : L.hero === "center" ? (
      <section class="relative overflow-hidden pt-44 pb-24 lg:pt-52 lg:pb-32 text-center">
        <ArrowMotif class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[46vw] max-w-2xl text-white/[0.035] pointer-events-none" />
        <div class="container-page relative z-10">
          <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Solutions", href: "/#solutions" }, { label: sol.label }]} tone="dark" class="mb-7 flex justify-center" />
            <p class="eyebrow justify-center mb-7" data-reveal>{sol.eyebrow}</p>
          <h1 class="display max-w-[16ch] mx-auto" data-reveal data-reveal-delay="1">
            {sol.title} <span class="dim">{sol.titleDim}</span>
          </h1>
          <p class="mt-8 max-w-xl mx-auto text-lg text-grey-2" data-reveal data-reveal-delay="2">{sol.tagline}</p>
          <div class="mt-10 flex flex-wrap justify-center gap-4" data-reveal data-reveal-delay="3">
            {ctas.map((c) => (
              <a href={c.href} class={`pill pill-${c.variant}`} data-magnetic="0.3">
                {c.label} <span class="arrow">{c.arrow}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="relative overflow-hidden pt-40 pb-24 lg:pt-48 lg:pb-32">
        <ArrowMotif class="absolute right-[3vw] top-1/2 -translate-y-1/2 w-[34vw] max-w-xl text-white/[0.04] pointer-events-none hidden md:block" />
        <div class="hair-arc hidden md:block" style="width:1000px;height:1000px;right:-320px;top:-220px;" />
        <div class="container-page relative z-10">
          <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Solutions", href: "/#solutions" }, { label: sol.label }]} tone="dark" class="mb-7" />
            <p class="eyebrow mb-7" data-reveal>{sol.eyebrow}</p>
          <h1 class="display max-w-[16ch]" data-reveal data-reveal-delay="1">
            {sol.title} <span class="dim">{sol.titleDim}</span>
          </h1>
          <p class="mt-8 max-w-xl text-lg text-grey-2" data-reveal data-reveal-delay="2">{sol.tagline}</p>
          <div class="mt-10 flex flex-wrap gap-4" data-reveal data-reveal-delay="3">
            {ctas.map((c) => (
              <a href={c.href} class={`pill pill-${c.variant}`} data-magnetic="0.3">
                {c.label} <span class="arrow">{c.arrow}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* ========================== OVERVIEW ========================== */}
  {
    L.hero === "split" ? (
      // Split heroes already show the image, so the overview is a text statement.
      <section class="section border-t border-line-soft">
        <div class="container-page grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <h2 class="display-sm" data-reveal>
            {sol.overviewHeading} <span class="dim">{sol.overviewHeadingDim}</span>
          </h2>
          <p class="text-lg leading-relaxed text-grey-2 max-w-xl lg:pt-2" data-reveal data-reveal-delay="1">
            {sol.overviewBody}
          </p>
        </div>
      </section>
    ) : (
      <ImageTextSplit
        image={sol.image}
        imageAlt={sol.label}
        mask={L.overviewMask}
        reverse={L.overviewReverse}
        heading={sol.overviewHeading}
        headingDim={sol.overviewHeadingDim}
        body={sol.overviewBody}
        grayscale={false}
        ctaHref="/strategy-call"
        ctaLabel="Discuss your build"
      />
    )
  }

  {/* ====================== FEATURES ====================== */}
  <section class={`section ${isLight ? "section-light" : ""}`}>
    <div class="container-page">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow">What's included</p>
        <h2 class={`display-sm mt-5 ${isLight ? "text-ink" : ""}`}>{sol.featuresHeading}</h2>
      </div>

      {
        L.features === "cards" ? (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {sol.features.map((f, i) => (
              <div class={cardClass} data-reveal data-reveal-delay={(i % 3) + 1}>
                <span class={iconWrap}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={f.glyph} />
                  </svg>
                </span>
                <h3 class={`mt-5 text-xl ${fTitle}`}>{f.title}</h3>
                <p class={`mt-3 text-sm leading-relaxed ${fDesc}`}>{f.desc}</p>
              </div>
            ))}
          </div>
        ) : (
          <div class="grid sm:grid-cols-2 gap-x-14">
            {sol.features.map((f, i) => (
              <div class={`flex items-start gap-4 py-6 border-b ${rowBorder}`} data-reveal data-reveal-delay={(i % 2) + 1}>
                <span class={`${iconWrap} shrink-0`}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={f.glyph} />
                  </svg>
                </span>
                <div>
                  <h3 class={`text-lg ${fTitle}`}>{f.title}</h3>
                  <p class={`mt-1.5 text-sm ${fDesc}`}>{f.desc}</p>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  {/* =========================== PROCESS =========================== */}
  <section class="section">
    <div class="container-page">
      <div class="max-w-2xl mb-14" data-reveal>
        <p class="eyebrow">How it works</p>
        <h2 class="display-sm mt-5">{sol.processHeading}</h2>
      </div>

      {
        L.process === "grid" ? (
          <div class="grid gap-px overflow-hidden rounded-[1.25rem] border border-line-soft bg-line-soft sm:grid-cols-2 lg:grid-cols-4">
            {sol.steps.map((st, i) => (
              <div class="bg-ink p-7 min-h-48 flex flex-col justify-between" data-reveal data-reveal-delay={(i % 4) + 1}>
                <span class="text-grey-3 text-sm tabular-nums">0{i + 1}</span>
                <div>
                  <h3 class="text-xl">{st.title}</h3>
                  <p class="mt-2 text-sm text-grey-2">{st.desc}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="max-w-3xl ml-3">
            {sol.steps.map((st, i) => (
              <div class="relative border-l border-line-soft pl-12 pb-10 last:pb-0" data-reveal data-reveal-delay={(i % 4) + 1}>
                <span class="absolute -left-[1.15rem] -top-1 grid place-items-center h-9 w-9 rounded-full bg-ink border border-line text-sm tabular-nums">
                  0{i + 1}
                </span>
                <h3 class="text-xl">{st.title}</h3>
                <p class="mt-2 text-grey-2 max-w-md">{st.desc}</p>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </section>

  {/* ============================ STATS ============================ */}
  <section class="pb-8">
    <StatsRow stats={sol.stats} />
  </section>

  {/* ============================= CTA ============================= */}
  <CtaBanner
    light={true}
    headline={sol.ctaHeadline}
    headlineDim={sol.ctaHeadlineDim}
    links={[
      { href: "/strategy-call", label: "Start a project", variant: "dark" },
      { href: "/#solutions", label: "Explore solutions", variant: "light" },
    ]}
  />
</BaseLayout>
