---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
---

<BaseLayout title="Contact Us · Pinnacle Route" navTheme="light">
  <main class="relative min-h-screen overflow-hidden bg-white text-ink pt-32 pb-24">
    
    <!-- Background Geometry -->
    <div class="hair-arc hidden md:block" style="width:900px;height:900px;right:-100px;top:-200px;"></div>

    <div class="container-page relative z-10">
      
      <!-- Hero Section -->
      <section class="mb-24 lg:mb-32">
        <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Contact" }]} tone="light" class="mb-8" />
        <h1 class="display !text-[clamp(3rem,8vw,6rem)] mb-4" data-reveal>Let's Connect!</h1>
        <p class="text-2xl md:text-3xl text-ink/60" data-reveal data-reveal-delay="1">Use the form below, or send us an email</p>
        
        <!-- Golden Decorative Arrow -->
        <div class="mt-12 md:mt-16 text-gold" data-reveal data-reveal-delay="2">
          <svg class="w-10 h-10 md:w-12 md:h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <polyline points="19 12 12 19 5 12"></polyline>
          </svg>
        </div>
      </section>

      <div class="w-full h-px bg-grey/20 mb-16 lg:mb-24"></div>

      <!-- Contact Form Section -->
      <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 mb-24 lg:mb-32">
        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-4xl font-medium text-ink">Contact us</h2>
        </div>
        
        <div class="lg:col-span-8">
          <form id="contact-form" class="flex flex-col gap-8 md:gap-12">
            <!-- Form Status Banner -->
            <div id="form-status" class="hidden rounded-lg p-4 mb-4 text-sm font-medium border"></div>

            <!-- Google reCAPTCHA API -->
            <script is:inline>
              (function() {
                const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
                const initRecaptcha = () => {
                  if (isLocal) {
                    const widgets = document.querySelectorAll('.g-recaptcha');
                    widgets.forEach(w => w.setAttribute('data-sitekey', '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI'));
                  }
                  const script = document.createElement('script');
                  script.src = "https://www.google.com/recaptcha/api.js";
                  script.async = true;
                  script.defer = true;
                  document.head.appendChild(script);
                };
                if (document.readyState === 'loading') {
                  document.addEventListener('DOMContentLoaded', initRecaptcha);
                } else {
                  initRecaptcha();
                }
              })();
            </script>
            
            <!-- Row 1 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">First Name *</label>
                <input 
                  type="text" 
                  id="firstName"
                  name="firstName"
                  required
                  placeholder="Enter first name"
                  class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors"
                />
              </div>
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">Last Name *</label>
                <input 
                  type="text" 
                  id="lastName"
                  name="lastName"
                  required
                  placeholder="Enter last name"
                  class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors"
                />
              </div>
            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">Email *</label>
                <input 
                  type="email" 
                  id="email"
                  name="email"
                  required
                  placeholder="Enter email"
                  class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors"
                />
              </div>
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">Company</label>
                <input 
                  type="text" 
                  id="company"
                  name="company"
                  placeholder="Company name or website"
                  class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors"
                />
              </div>
            </div>

            <!-- Row 3 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">Phone Number</label>
                <input 
                  type="tel" 
                  id="phone"
                  name="phone"
                  placeholder="124-456-7890"
                  class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors"
                />
              </div>
              <div class="flex flex-col gap-3">
                <label class="text-sm font-semibold text-ink">Budget Range</label>
                <div class="relative">
                  <select id="budget" name="budget" class="w-full bg-transparent border-b border-grey/20 text-ink pb-3 focus:outline-none focus:border-gold transition-colors appearance-none pr-8">
                    <option value="" disabled selected class="bg-white text-ink/40">Please select...</option>
                    <option value="under_10k" class="bg-white text-ink">Under $10,000</option>
                    <option value="10k_50k" class="bg-white text-ink">$10,000 - $50,000</option>
                    <option value="50k_100k" class="bg-white text-ink">$50,000 - $100,000</option>
                    <option value="over_100k" class="bg-white text-ink">$100,000+</option>
                  </select>
                  <svg class="absolute right-0 bottom-4 text-ink/60 pointer-events-none" style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </div>
              </div>
            </div>

            <!-- Row 4 -->
            <div class="flex flex-col gap-3 mt-4">
              <label class="text-sm font-semibold text-ink">Message</label>
              <textarea 
                id="message"
                name="message"
                placeholder="Tell us about your project. What problems can we help you solve?"
                rows="1"
                class="w-full bg-transparent border-b border-grey/20 text-ink placeholder-ink/40 pb-3 focus:outline-none focus:border-gold transition-colors resize-y min-h-[40px]"
              ></textarea>
            </div>

            <!-- Footer -->
            <div class="flex flex-col gap-8 mt-4">
              <!-- Checkbox & Captcha -->
              <div class="flex flex-col md:flex-row items-start justify-between gap-6">
                <label class="flex items-center gap-3 cursor-pointer group pt-2">
                  <div class="relative flex items-center justify-center w-5 h-5 border border-grey/20 rounded bg-transparent group-hover:border-gold transition-colors">
                    <input type="checkbox" id="newsletter" name="newsletter" class="peer sr-only" />
                    <svg class="w-3 h-3 text-gold opacity-0 peer-checked:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="text-sm text-ink/60 group-hover:text-ink transition-colors">Subscribe to newsletter</span>
                </label>

                <!-- reCAPTCHA Widget -->
                <div class="w-full md:w-auto flex md:justify-end overflow-hidden rounded-md border border-grey/10 shadow-sm">
                  <div id="contact-recaptcha" class="g-recaptcha" data-sitekey={import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI'} data-theme="light"></div>
                </div>
              </div>

              <!-- Submit Button -->
              <div class="flex justify-end border-t border-grey/10 pt-8">
                <button type="submit" id="submit-btn" class="pill pill-dark w-full md:w-auto text-center justify-center transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                  <span id="btn-text">Submit Inquiry</span>
                  <span id="btn-arrow" class="arrow">↗</span>
                  <div id="btn-loader" class="hidden ml-2 w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div>
                </button>
              </div>
            </div>
            
          </form>

          <script>
            document.addEventListener("astro:page-load", () => {
              const form = document.getElementById('contact-form') as HTMLFormElement;
              const statusBanner = document.getElementById('form-status');
              const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
              const btnText = document.getElementById('btn-text');
              const btnArrow = document.getElementById('btn-arrow');
              const btnLoader = document.getElementById('btn-loader');

              if (form) {
                form.addEventListener('submit', async (e) => {
                  e.preventDefault();
                  
                  // Guard against reCAPTCHA failing to load (domain error, network, blocker)
                  const gre = (window as any).grecaptcha;
                  if (!gre || typeof gre.getResponse !== 'function') {
                    if (statusBanner) {
                      statusBanner.textContent = 'Security check could not load. Please disable any ad/script blockers, refresh the page, and try again.';
                      statusBanner.className = 'rounded-lg p-4 mb-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-600 block';
                    }
                    return;
                  }
                  const recaptchaResponse = gre.getResponse();
                  if (!recaptchaResponse) {
                    if (statusBanner) {
                      statusBanner.textContent = 'Please complete the reCAPTCHA to verify you are human.';
                      statusBanner.className = 'rounded-lg p-4 mb-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-600 block';
                    }
                    return;
                  }

                  // UI Loading State
                  if (submitBtn) submitBtn.disabled = true;
                  if (btnText) btnText.textContent = 'Sending...';
                  if (btnArrow) btnArrow.classList.add('hidden');
                  if (btnLoader) btnLoader.classList.remove('hidden');
                  if (statusBanner) statusBanner.classList.add('hidden');

                  const formData = new FormData(form);
                  const data = {
                    firstName: formData.get('firstName'),
                    lastName: formData.get('lastName'),
                    email: formData.get('email'),
                    company: formData.get('company'),
                    phone: formData.get('phone'),
                    budget: formData.get('budget'),
                    message: formData.get('message'),
                    newsletter: formData.get('newsletter') === 'on',
                    recaptchaToken: recaptchaResponse
                  };

                  try {
                    const res = await fetch('/api/public/contact', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify(data)
                    });
                    
                    const result = await res.json();
                    
                    if (statusBanner) {
                      statusBanner.classList.remove('hidden');
                      statusBanner.textContent = result.message;
                      
                      if (result.success) {
                        statusBanner.className = 'rounded-lg p-4 mb-4 text-sm font-medium border border-green-500/20 bg-green-500/10 text-green-700 block';
                        form.reset();
                        gre.reset();
                        if (btnText) btnText.textContent = 'Sent Successfully';
                      } else {
                        statusBanner.className = 'rounded-lg p-4 mb-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-600 block';
                        if (submitBtn) submitBtn.disabled = false;
                        if (btnText) btnText.textContent = 'Submit Inquiry';
                        if (btnArrow) btnArrow.classList.remove('hidden');
                      }
                    }
                  } catch (error) {
                    if (statusBanner) {
                      statusBanner.textContent = 'A network error occurred. Please try again.';
                      statusBanner.className = 'rounded-lg p-4 mb-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-600 block';
                    }
                    if (submitBtn) submitBtn.disabled = false;
                    if (btnText) btnText.textContent = 'Submit Inquiry';
                    if (btnArrow) btnArrow.classList.remove('hidden');
                  } finally {
                    if (btnLoader) btnLoader.classList.add('hidden');
                  }
                });
              }
            });
          </script>
        </div>
      </section>

      <div class="w-full h-px bg-grey/20 mb-16"></div>

      <!-- Direct Contact Links -->
      <section class="mb-24">
        <div class="flex flex-col border-b border-grey/20">
          <!-- Projects -->
          <a href="mailto:projects@pinnacleroute.com" class="group flex flex-col md:flex-row items-start md:items-center justify-between py-10 border-t border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <h3 class="text-3xl md:text-4xl text-ink/60 group-hover:text-ink transition-colors w-full md:w-1/3 mb-4 md:mb-0">Projects</h3>
            <div class="flex items-center justify-between w-full md:w-2/3">
              <span class="text-3xl md:text-5xl font-medium tracking-tight group-hover:text-gold transition-colors break-all">projects@pinnacleroute.com</span>
              <svg class="w-8 h-8 md:w-10 md:h-10 text-ink/60 group-hover:text-gold transition-colors transform group-hover:translate-x-2 group-hover:-translate-y-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 19L19 5M19 5v14M19 5H5"/></svg>
            </div>
          </a>

          <!-- Careers -->
          <a href="mailto:join@pinnacleroute.com" class="group flex flex-col md:flex-row items-start md:items-center justify-between py-10 border-t border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <h3 class="text-3xl md:text-4xl text-ink/60 group-hover:text-ink transition-colors w-full md:w-1/3 mb-4 md:mb-0">Careers</h3>
            <div class="flex items-center justify-between w-full md:w-2/3">
              <span class="text-3xl md:text-5xl font-medium tracking-tight group-hover:text-gold transition-colors break-all">join@pinnacleroute.com</span>
              <svg class="w-8 h-8 md:w-10 md:h-10 text-ink/60 group-hover:text-gold transition-colors transform group-hover:translate-x-2 group-hover:-translate-y-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 19L19 5M19 5v14M19 5H5"/></svg>
            </div>
          </a>

          <!-- Media -->
          <a href="mailto:info@pinnacleroute.com" class="group flex flex-col md:flex-row items-start md:items-center justify-between py-10 border-t border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <h3 class="text-3xl md:text-4xl text-ink/60 group-hover:text-ink transition-colors w-full md:w-1/3 mb-4 md:mb-0">Media</h3>
            <div class="flex items-center justify-between w-full md:w-2/3">
              <span class="text-3xl md:text-5xl font-medium tracking-tight group-hover:text-gold transition-colors break-all">info@pinnacleroute.com</span>
              <svg class="w-8 h-8 md:w-10 md:h-10 text-ink/60 group-hover:text-gold transition-colors transform group-hover:translate-x-2 group-hover:-translate-y-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 19L19 5M19 5v14M19 5H5"/></svg>
            </div>
          </a>
        </div>
      </section>

      <!-- Social Links -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 pt-8">
        <div class="md:col-span-4">
          <h3 class="text-3xl md:text-4xl text-ink/60">Social</h3>
        </div>
        
        <div class="md:col-span-8 flex flex-col">
          <a href="https://www.linkedin.com/company/pinnacle-route" target="_blank" rel="noopener noreferrer" aria-label="Pinnacle Route on LinkedIn" class="group flex items-center justify-between py-6 border-b border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <span class="text-2xl md:text-3xl font-medium group-hover:text-gold transition-colors">LinkedIn</span>
            <svg class="w-6 h-6 text-ink/60 group-hover:text-ink transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          
          <a href="https://x.com/PinnacleRoute" target="_blank" rel="noopener noreferrer" aria-label="Pinnacle Route on Twitter X" class="group flex items-center justify-between py-6 border-b border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <span class="text-2xl md:text-3xl font-medium group-hover:text-gold transition-colors">Twitter</span>
            <svg class="w-6 h-6 text-ink/60 group-hover:text-ink transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          
          <a href="https://www.instagram.com/pinnacle_route/" target="_blank" rel="noopener noreferrer" aria-label="Pinnacle Route on Instagram" class="group flex items-center justify-between py-6 border-b border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <span class="text-2xl md:text-3xl font-medium group-hover:text-gold transition-colors">Instagram</span>
            <svg class="w-6 h-6 text-ink/60 group-hover:text-ink transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>

          <a href="https://api.whatsapp.com/send/?phone=919621391943&text=Hi+Pinnacle+Route%2C+I+would+like+to+book+a+free+strategy+session.&type=phone_number&app_absent=0" target="_blank" rel="noopener noreferrer" aria-label="Chat with Pinnacle Route on WhatsApp" class="group flex items-center justify-between py-6 border-b border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <span class="text-2xl md:text-3xl font-medium group-hover:text-gold transition-colors">WhatsApp</span>
            <svg class="w-6 h-6 text-ink/60 group-hover:text-ink transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          </a>

          <a href="https://www.threads.net/@pinnacle_route" target="_blank" rel="noopener noreferrer" aria-label="Pinnacle Route on Threads" class="group flex items-center justify-between py-6 border-b border-grey/20 hover:bg-grey/5 transition-colors px-4 -mx-4 rounded-xl">
            <span class="text-2xl md:text-3xl font-medium group-hover:text-gold transition-colors">Threads</span>
            <svg class="w-6 h-6 text-ink/60 group-hover:text-ink transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-1.156 16.5c-2.344 0-4.047-1.469-4.047-3.672 0-2.281 1.781-4.062 4.297-4.062 1.953 0 3.25 1.016 3.688 2.516h-1.547c-.312-1-1.078-1.578-2.156-1.578-1.594 0-2.656 1.344-2.656 3.109s1.016 2.766 2.562 2.766c1.172 0 1.984-.578 2.297-1.547h1.562c-.438 1.531-1.781 2.468-4 2.468zm3.984-7.468h-1.609v-1.719h1.609v1.719zm0 7.312h-1.609v-6.906h1.609v6.906z"/></svg>
          </a>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>
