---
/**
 * Our Expertise
 * -------------
 * Detailed breakdown of the 4 main service areas.
 */
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import StickySubNav from "@/components/ui/StickySubNav.astro";
import ExpertiseSection from "@/components/sections/ExpertiseSection.astro";
import CtaBanner from "@/components/sections/CtaBanner.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";

import { db, ExpertiseCategory } from "astro:db";

const rawExpertiseData = await db.select().from(ExpertiseCategory);
const expertiseData = rawExpertiseData.sort((a, b) => a.orderIndex - b.orderIndex).map((cat, index) => {
  const number = String(index + 1).padStart(2, '0');
  return {
  number,
  id: cat.id,
  navLabel: `${number} ${cat.id.charAt(0).toUpperCase() + cat.id.slice(1)}`, // E.g., '01 Technology'
  titleLine1: cat.titleLine1,
  titleLine2: cat.titleLine2,
  description: cat.description,
  image: cat.mediaUrl,
  services: cat.servicesJson as any[]
  };
});

// Alternate masks for visual variety
const masks = ["br", "tr", "bl", "arch"] as const;
---

<BaseLayout
  title="Our Expertise · Pinnacle Route"
  description="Explore our capabilities in Technology, Design, Strategy, and Growth."
  navTheme="light"
  strictNav={true}
>
  <!-- ===================== HERO ===================== -->
  <section class="relative h-[65vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-ink">
    <div class="absolute inset-0 z-0">
      <video
        class="h-full w-full object-cover opacity-30 grayscale"
        autoplay muted loop playsinline
        preload="metadata"
      >
        <source src="/assets/videos/about-hero.mp4" type="video/mp4" />
      </video>
    </div>
    
    <div class="container-page relative z-10 text-center">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Our Expertise" }]} tone="dark" class="mb-6 flex justify-center" />
      <h1 class="display-sm !text-[clamp(3rem,6vw,5rem)] text-white" data-reveal>
        Decades of Proven Approach
      </h1>
    </div>
  </section>

  <!-- ===================== STICKY SUB-NAV ===================== -->
  <StickySubNav categories={expertiseData} />

  <!-- ===================== EXPERTISE SECTIONS ===================== -->
  <div class="bg-paper">
    {
      expertiseData.map((category, index) => (
        <ExpertiseSection 
          category={category} 
          mask={masks[index % masks.length]} 
        />
      ))
    }
  </div>

  <!-- Dark closing CTA — flows seamlessly into the footer -->
  <CtaBanner
    eyebrow="Let's talk"
    headline="We'd love to hear about"
    headlineDim="your project"
    links={[{ href: "/strategy-call", label: "Start a project", variant: "light" }]}
  />
</BaseLayout>
