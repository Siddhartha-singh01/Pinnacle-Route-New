---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import { verifyCredentials, createSessionToken, SESSION_COOKIE } from "@/lib/auth";
import { loginLimiter } from "@/lib/login-limiter";

let error = "";

if (Astro.request.method === "POST") {
  const ip = Astro.clientAddress || Astro.request.headers.get("x-forwarded-for") || "unknown";

  const data = await Astro.request.formData();
  const username = data.get("username");
  const password = data.get("password");

  if (loginLimiter.isLimited(ip)) {
    error = "Too many failed attempts. Please wait 15 minutes and try again.";
  } else if (verifyCredentials(username, password)) {
    Astro.cookies.set(SESSION_COOKIE, createSessionToken(String(username)), {
      path: "/",
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "strict",
      maxAge: 60 * 60 * 24 * 7, // 1 week
    });
    return Astro.redirect("/admin");
  } else {
    error = "Invalid username or password.";
  }
}
---

<BaseLayout title="Admin Login · Pinnacle Route" navTheme="light" strictNav={true}>
  <main class="min-h-svh bg-[#fafafb] flex items-center justify-center pt-24 px-4 text-black">
    <div class="w-full max-w-md bg-white border border-line-soft rounded-2xl p-8 relative overflow-hidden shadow-xl">
      
      <div class="relative z-10">
        <div class="flex flex-col items-center mb-8">
          <svg class="w-10 h-10 text-gold mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <h1 class="text-2xl font-semibold text-black">Admin Secure Login</h1>
          <p class="text-sm text-grey mt-2">Restricted access area.</p>
        </div>

        {error && (
          <div class="bg-red-500/10 border border-red-500/20 text-red-600 text-sm p-3 rounded-lg mb-6 text-center">
            {error}
          </div>
        )}

        <form method="POST" class="flex flex-col gap-6">
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold text-grey uppercase tracking-wider">Username</label>
            <input 
              type="text" 
              name="username" 
              required
              class="w-full bg-white border border-ink/15 text-black px-4 py-3 rounded-lg focus:outline-none focus:border-gold transition-colors"
            />
          </div>
          
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold text-grey uppercase tracking-wider">Password</label>
            <input 
              type="password" 
              name="password" 
              required
              class="w-full bg-white border border-ink/15 text-black px-4 py-3 rounded-lg focus:outline-none focus:border-gold transition-colors"
            />
          </div>

          <button type="submit" class="w-full bg-black text-white font-semibold py-3 rounded-lg hover:bg-gold transition-colors mt-2">
            Authenticate
          </button>
        </form>
      </div>
    </div>
  </main>

  <style is:global>
    body, a, button, input, textarea, select, .cursor-pointer {
      cursor: auto !important;
    }
    #custom-cursor {
      display: none !important;
    }
  </style>
</BaseLayout>
