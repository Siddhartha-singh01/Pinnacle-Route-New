---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getCollection } from 'astro:content';
import { db, Inquiries } from 'astro:db';
import { verifySessionToken } from '@/lib/auth';

// Ensure user is authenticated
const sessionCookie = Astro.cookies.get('admin_session');
if (!verifySessionToken(sessionCookie?.value)) {
  return Astro.redirect('/admin/login');
}

const posts = await getCollection('blog');
const totalViews = posts.reduce((sum, post) => sum + (post.data.views || 0), 0);

// Get Real Lead Count from DB
const allInquiries = await db.select().from(Inquiries);
const leadCount = allInquiries.length;

// Vercel API Integration for Build Status
const vercelToken = import.meta.env.VERCEL_ACCESS_TOKEN || process.env.VERCEL_ACCESS_TOKEN;
const projectId = 'prj_wkKXPYCkodxYbdqc09KBIwA4grF1';

let buildStatus = 'Unknown';
let isOperational = true;

if (vercelToken) {
  try {
    const res = await fetch(`https://api.vercel.com/v6/deployments?projectId=${projectId}&limit=1`, {
      headers: {
        Authorization: `Bearer ${vercelToken}`,
      },
    });
    if (res.ok) {
      const data = await res.json();
      if (data.deployments && data.deployments.length > 0) {
        const latestState = data.deployments[0].state; // e.g., 'READY', 'ERROR', 'BUILDING'
        if (latestState === 'READY') buildStatus = 'Passing';
        else if (latestState === 'ERROR') {
          buildStatus = 'Failed';
          isOperational = false;
        }
        else buildStatus = latestState;
      }
    } else {
      buildStatus = 'API Error';
    }
  } catch (error) {
    buildStatus = 'API Error';
  }
} else {
  buildStatus = 'Token Required';
}
---

<AdminLayout title="Dashboard Overview" activeTab="overview">
  <div class="max-w-5xl">
    <h1 class="text-2xl font-semibold text-white mb-8">Dashboard Overview</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Total Views -->
      <div class="bg-surface border border-line-soft rounded-xl p-6 relative overflow-hidden">
        <div class="text-[0.65rem] font-bold text-grey-2 uppercase tracking-widest mb-2">Total Blog Views</div>
        <div class="text-4xl font-display text-white">{totalViews.toLocaleString()}</div>
        <div class="text-xs text-green-400 mt-2">↑ 12% from last month</div>
        <svg class="absolute right-0 bottom-0 text-line opacity-50" width="120" height="80" viewBox="0 0 120 80" fill="none"><path d="M0 80 Q 30 20 60 40 T 120 10 L 120 80 Z" fill="currentColor"/></svg>
      </div>

      <!-- Published Posts -->
      <div class="bg-surface border border-line-soft rounded-xl p-6">
        <div class="text-[0.65rem] font-bold text-grey-2 uppercase tracking-widest mb-2">Published Posts</div>
        <div class="text-4xl font-display text-white">{posts.length}</div>
        <div class="text-xs text-grey-2 mt-2">Latest: {posts.sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0]?.data.title.substring(0, 20)}...</div>
      </div>

      <!-- Total Leads -->
      <div class="bg-surface border border-line-soft rounded-xl p-6 relative overflow-hidden group hover:border-[#CAA154]/50 transition-colors">
        <a href="/admin/leads" class="absolute inset-0 z-10"></a>
        <div class="text-[0.65rem] font-bold text-grey-2 uppercase tracking-widest mb-2 flex justify-between items-center">
          Total Leads & Inquiries
          <svg class="w-3 h-3 text-grey-2 group-hover:text-gold transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </div>
        <div class="text-4xl font-display text-white">{leadCount}</div>
        <div class="text-xs text-green-400 mt-2">View details →</div>
      </div>
    </div>

    <h2 class="text-lg font-semibold text-white mb-4">Vercel Website Health</h2>
    <div class="bg-surface border border-line-soft rounded-xl p-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <div class={`w-2 h-2 rounded-full ${isOperational ? 'bg-green-500' : 'bg-red-500'}`}></div>
          <span class="text-sm font-medium text-white">System Status</span>
        </div>
        <p class="text-xs text-grey-2">{isOperational ? 'All systems operational.' : 'Service disruption detected.'}</p>
      </div>
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-medium text-white">Average Load Time</span>
        </div>
        <p class="text-lg text-gold font-display">0.8s</p>
      </div>
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="text-sm font-medium text-white">Build Status</span>
        </div>
        <p class={`text-xs px-2 py-1 border rounded inline-block ${
          buildStatus === 'Passing' ? 'bg-green-500/10 text-green-500 border-green-500/20' : 
          buildStatus === 'Failed' ? 'bg-red-500/10 text-red-500 border-red-500/20' : 
          buildStatus === 'Token Required' ? 'bg-orange-500/10 text-orange-400 border-orange-500/20' :
          'bg-grey/10 text-grey-2 border-grey/20'
        }`}>
          {buildStatus}
        </p>
        {buildStatus === 'Token Required' && (
          <p class="text-[10px] text-grey-2 mt-2">Add VERCEL_ACCESS_TOKEN to .env</p>
        )}
      </div>
    </div>

  </div>
</AdminLayout>
