---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getBlogPosts } from '@/lib/blog';

const sortedPosts = await getBlogPosts();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric'
  });
};
---

<AdminLayout title="Blog Posts" activeTab="blog">
  <div class="max-w-6xl">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-semibold text-white">Blog Posts</h1>
      <a href="/admin/blog/new" class="px-4 py-2 bg-white text-black font-medium text-sm rounded-lg hover:bg-grey transition-colors flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        New Post
      </a>
    </div>

    <div class="bg-surface border border-line-soft rounded-xl overflow-hidden">
      <table class="w-full text-left text-sm">
        <thead class="bg-ink border-b border-line-soft text-grey-2 uppercase tracking-wider text-[0.65rem] font-bold">
          <tr>
            <th class="px-6 py-4">Title</th>
            <th class="px-6 py-4">Category</th>
            <th class="px-6 py-4">Views</th>
            <th class="px-6 py-4">Published</th>
            <th class="px-6 py-4">Status</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line-soft">
          {sortedPosts.map(post => (
            <tr class="hover:bg-surface-2 transition-colors">
              <td class="px-6 py-4">
                <div class="text-white font-medium mb-1 truncate max-w-sm">{post.data.title}</div>
                <div class="text-xs text-grey-2 truncate max-w-sm">{post.data.description}</div>
              </td>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded text-[0.65rem] font-medium bg-white/5 border border-white/10 text-grey-2 whitespace-nowrap">
                  {post.data.category}
                </span>
              </td>
              <td class="px-6 py-4 text-grey-2">{post.data.views.toLocaleString()}</td>
              <td class="px-6 py-4 text-grey-2 whitespace-nowrap">{formatDate(post.data.pubDate)}</td>
              <td class="px-6 py-4">
                <span class="flex items-center gap-1.5 text-xs text-green-400">
                  <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div> Published
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <a href={`/blog/${post.id}`} target="_blank" class="text-xs text-gold hover:text-white transition-colors">View</a>
              </td>
            </tr>
          ))}
          {sortedPosts.length === 0 && (
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-grey-2">No posts found.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
