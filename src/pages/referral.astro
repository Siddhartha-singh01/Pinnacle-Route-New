---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumb from "@/components/ui/Breadcrumb.astro";
---

<BaseLayout title="Partner Program · Pinnacle Route" navTheme="dark">
  <main class="relative min-h-screen overflow-hidden bg-ink pt-32 pb-24 text-white">
    
    <!-- Background Geometry -->
    <div class="hair-arc hidden md:block" style="width:1200px;height:1200px;right:-400px;top:-300px;opacity:0.6;"></div>

    <div class="container-page relative z-10">
      
      <!-- Hero Section -->
      <section class="mb-32 lg:mb-40 pt-10">
        <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Partner Program" }]} tone="dark" class="mb-8" />
        <p class="eyebrow mb-8 text-gold" data-reveal>Partnership Program</p>
        <h1 class="display !text-[clamp(3.5rem,10vw,8rem)] mb-6 leading-none">
          <span class="block" data-reveal data-reveal-delay="1">Introduce us.</span>
          <span class="block dim" data-reveal data-reveal-delay="2">Earn with us.</span>
        </h1>
        <div class="mt-12 grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
          <p class="max-w-xl text-xl md:text-2xl text-grey-2 leading-relaxed" data-reveal data-reveal-delay="3">
            Know a business that needs elite digital solutions? Connect us, and we'll share our success. Earn a <span class="text-white font-medium">10% commission</span> on the first year's contract value for every successful referral.
          </p>
          <a href="#referral-form" class="pill pill-light self-start lg:justify-self-end" data-magnetic="0.3" data-reveal data-reveal-delay="4">
            Become a Partner <span class="arrow">↓</span>
          </a>
        </div>
      </section>

      <!-- How It Works Section -->
      <section class="mb-32 lg:mb-40 relative">
        <h2 class="text-3xl md:text-4xl font-medium mb-16" data-reveal>How the process works</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          
          <!-- Step 1 -->
          <div class="group relative p-8 lg:p-12 border border-line-soft rounded-2xl bg-surface hover:bg-surface-2 transition-colors overflow-hidden" data-reveal>
            <div class="absolute -right-8 -top-8 text-[12rem] font-bold text-line-soft leading-none group-hover:text-gold/10 transition-colors pointer-events-none">1</div>
            <div class="relative z-10">
              <h3 class="text-2xl font-medium mb-4 text-white group-hover:text-gold transition-colors">01. Connect</h3>
              <p class="text-grey-2 text-lg">Introduce us to decision-makers in your network who are actively seeking custom software, AI automation, or digital growth solutions.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="group relative p-8 lg:p-12 border border-line-soft rounded-2xl bg-surface hover:bg-surface-2 transition-colors overflow-hidden" data-reveal data-reveal-delay="1">
            <div class="absolute -right-8 -top-8 text-[12rem] font-bold text-line-soft leading-none group-hover:text-gold/10 transition-colors pointer-events-none">2</div>
            <div class="relative z-10">
              <h3 class="text-2xl font-medium mb-4 text-white group-hover:text-gold transition-colors">02. We Close</h3>
              <p class="text-grey-2 text-lg">Our elite team handles the strategy, the pitch, and the closing process. You don't have to sell anything—just make the introduction.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="group relative p-8 lg:p-12 border border-line-soft rounded-2xl bg-surface hover:bg-surface-2 transition-colors overflow-hidden" data-reveal data-reveal-delay="2">
            <div class="absolute -right-8 -top-8 text-[12rem] font-bold text-line-soft leading-none group-hover:text-gold/10 transition-colors pointer-events-none">3</div>
            <div class="relative z-10">
              <h3 class="text-2xl font-medium mb-4 text-white group-hover:text-gold transition-colors">03. You Earn</h3>
              <p class="text-grey-2 text-lg">Receive a 10% commission of the first year's contract value as soon as the client signs and the first invoice is settled. No caps.</p>
            </div>
          </div>

        </div>
      </section>

      <div class="w-full h-px bg-line-soft mb-24 lg:mb-32"></div>

      <!-- Referral Form Section -->
      <section id="referral-form" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mb-24 lg:mb-32">
        <div class="lg:col-span-5" data-reveal>
          <h2 class="text-4xl md:text-5xl font-medium text-white mb-6">Submit a Referral</h2>
          <p class="text-xl text-grey-2 mb-12">Fill out the details below to register your referral. We will reach out to you first before contacting the prospect.</p>
          
          <div class="p-8 border border-gold/20 rounded-2xl bg-gold/5 backdrop-blur-sm">
            <h4 class="text-lg font-medium text-gold mb-2">Partner Guarantee</h4>
            <p class="text-grey-2 text-sm leading-relaxed">Your relationships are your most valuable asset. We guarantee absolute professionalism and discretion with every introduction you make.</p>
          </div>
        </div>
        
        <div class="lg:col-span-7" data-reveal data-reveal-delay="1">
          <form id="referral-form-el" class="flex flex-col gap-10 md:gap-14 bg-surface p-8 md:p-12 rounded-3xl border border-line-soft" novalidate>
            
            <!-- Form Status Banner -->
            <div id="referral-status" class="hidden rounded-lg p-4 text-sm font-medium border"></div>

            <!-- About You -->
            <div>
              <h3 class="text-xl font-medium text-white mb-6 flex items-center gap-3">
                <span class="w-6 h-px bg-gold"></span> Your Details
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
                <div class="flex flex-col gap-3">
                  <label for="ref-name" class="text-sm font-semibold text-white">Full Name *</label>
                  <input 
                    type="text"
                    id="ref-name"
                    name="firstName"
                    required
                    autocomplete="name"
                    placeholder="Enter your name"
                    class="w-full bg-transparent border-b border-line-soft text-white placeholder-grey-3 pb-3 focus:outline-none focus:border-gold transition-colors"
                  />
                </div>
                <div class="flex flex-col gap-3">
                  <label for="ref-email" class="text-sm font-semibold text-white">Email Address *</label>
                  <input 
                    type="email"
                    id="ref-email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="Enter your email"
                    class="w-full bg-transparent border-b border-line-soft text-white placeholder-grey-3 pb-3 focus:outline-none focus:border-gold transition-colors"
                  />
                </div>
              </div>
            </div>

            <!-- About Them -->
            <div class="pt-6 border-t border-line-soft">
              <h3 class="text-xl font-medium text-white mb-6 flex items-center gap-3">
                <span class="w-6 h-px bg-gold"></span> Prospect Details
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 mb-8 md:mb-10">
                <div class="flex flex-col gap-3">
                  <label for="ref-contact-name" class="text-sm font-semibold text-white">Contact Name *</label>
                  <input 
                    type="text"
                    id="ref-contact-name"
                    name="prospectName"
                    required
                    placeholder="Who are we meeting?"
                    class="w-full bg-transparent border-b border-line-soft text-white placeholder-grey-3 pb-3 focus:outline-none focus:border-gold transition-colors"
                  />
                </div>
                <div class="flex flex-col gap-3">
                  <label for="ref-company" class="text-sm font-semibold text-white">Company Name *</label>
                  <input 
                    type="text"
                    id="ref-company"
                    name="company"
                    required
                    placeholder="Their organization"
                    class="w-full bg-transparent border-b border-line-soft text-white placeholder-grey-3 focus:outline-none focus:border-gold transition-colors"
                  />
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <label for="ref-notes" class="text-sm font-semibold text-white">Context / Notes</label>
                <textarea 
                  id="ref-notes"
                  name="message"
                  placeholder="How do you know them? What challenges are they facing?"
                  rows="3"
                  class="w-full bg-transparent border-b border-line-soft text-white placeholder-grey-3 pb-3 focus:outline-none focus:border-gold transition-colors resize-y min-h-[72px]"
                ></textarea>
              </div>
            </div>

            <!-- Footer -->
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pt-6 border-t border-line-soft">
              <label class="flex items-center gap-3 cursor-pointer group">
                <div class="relative flex items-center justify-center w-5 h-5 border border-line-soft rounded bg-transparent group-hover:border-gold transition-colors">
                  <input type="checkbox" name="terms" id="ref-terms" class="peer sr-only" required />
                  <svg class="w-3 h-3 text-gold opacity-0 peer-checked:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="text-sm text-grey-2 group-hover:text-white transition-colors">I accept the Partner Terms &amp; Conditions</span>
              </label>

              <button type="submit" id="referral-submit-btn" class="pill pill-light" data-magnetic="0.3">
                <span id="ref-btn-text">Submit Referral</span>
                <span id="ref-btn-arrow" class="arrow">↗</span>
                <div id="ref-btn-loader" class="hidden ml-2 w-4 h-4 border-2 border-ink/20 border-t-ink rounded-full animate-spin"></div>
              </button>
            </div>
            
          </form>

          <script>
            document.addEventListener("astro:page-load", () => {
              const form = document.getElementById('referral-form-el') as HTMLFormElement;
              const statusBanner = document.getElementById('referral-status');
              const submitBtn = document.getElementById('referral-submit-btn') as HTMLButtonElement;
              const btnText = document.getElementById('ref-btn-text');
              const btnArrow = document.getElementById('ref-btn-arrow');
              const btnLoader = document.getElementById('ref-btn-loader');

              if (!form) return;

              form.addEventListener('submit', async (e) => {
                e.preventDefault();

                // Client-side validation
                const fd = new FormData(form);
                const firstName = (fd.get('firstName') as string || '').trim();
                const email = (fd.get('email') as string || '').trim();
                const prospectName = (fd.get('prospectName') as string || '').trim();
                const company = (fd.get('company') as string || '').trim();
                const message = (fd.get('message') as string || '').trim();
                const terms = fd.get('terms');

                const showError = (msg: string) => {
                  if (statusBanner) {
                    statusBanner.textContent = msg;
                    statusBanner.className = 'rounded-lg p-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-400 block';
                    statusBanner.classList.remove('hidden');
                  }
                };

                if (!firstName || !email || !prospectName || !company) {
                  showError('Please fill in all required fields marked with *');
                  return;
                }
                if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                  showError('Please enter a valid email address.');
                  return;
                }
                if (!terms) {
                  showError('Please accept the Partner Terms & Conditions to continue.');
                  return;
                }

                // Build a descriptive message for the admin email
                const fullMessage = [
                  `Referral submitted by: ${firstName} <${email}>`,
                  `Prospect Contact: ${prospectName}`,
                  `Prospect Company: ${company}`,
                  message ? `Notes: ${message}` : '',
                ].filter(Boolean).join('\n\n');

                // Loading state
                if (submitBtn) submitBtn.disabled = true;
                if (btnText) btnText.textContent = 'Sending...';
                if (btnArrow) btnArrow.classList.add('hidden');
                if (btnLoader) btnLoader.classList.remove('hidden');
                if (statusBanner) statusBanner.classList.add('hidden');

                try {
                  const res = await fetch('/api/public/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                      firstName,
                      lastName: '(Partner Referral)',
                      email,
                      company,
                      message: fullMessage,
                      projectType: `Partner Referral — ${prospectName} at ${company}`,
                      recaptchaToken: 'referral-internal',
                    }),
                  });

                  const result = await res.json();

                  if (statusBanner) {
                    statusBanner.classList.remove('hidden');
                    if (result.success) {
                      statusBanner.textContent = '✓ Referral submitted! We\'ll reach out to you within 24 hours before contacting the prospect.';
                      statusBanner.className = 'rounded-lg p-4 text-sm font-medium border border-green-500/20 bg-green-500/10 text-green-400 block';
                      form.reset();
                      if (btnText) btnText.textContent = 'Referral Sent ✓';
                    } else {
                      statusBanner.textContent = result.message || 'Something went wrong. Please try again.';
                      statusBanner.className = 'rounded-lg p-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-400 block';
                      if (submitBtn) submitBtn.disabled = false;
                      if (btnText) btnText.textContent = 'Submit Referral';
                      if (btnArrow) btnArrow.classList.remove('hidden');
                    }
                  }
                } catch {
                  if (statusBanner) {
                    statusBanner.textContent = 'A network error occurred. Please try again.';
                    statusBanner.className = 'rounded-lg p-4 text-sm font-medium border border-red-500/20 bg-red-500/10 text-red-400 block';
                    statusBanner.classList.remove('hidden');
                  }
                  if (submitBtn) submitBtn.disabled = false;
                  if (btnText) btnText.textContent = 'Submit Referral';
                  if (btnArrow) btnArrow.classList.remove('hidden');
                } finally {
                  if (btnLoader) btnLoader.classList.add('hidden');
                }
              });
            });
          </script>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>
