---
/**
 * Reviews Section
 * ---------------
 * Social-proof band showing ratings from top third-party review platforms,
 * plus an "as featured in" press row. Uses fixed colors (theme-independent)
 * so it renders consistently on light- or dark-themed pages.
 */
import { reviewRatings, pressMentions } from "@/data/reviews";
---

<section class="section section-light relative overflow-hidden">
  <div class="container-page relative z-10">
    <div class="max-w-2xl mb-14" data-reveal>
      <img src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route Logo" loading="lazy" decoding="async" class="h-14 mb-6 logo-feedback" />
      <p class="text-[0.72rem] font-semibold tracking-[0.18em] uppercase text-[#CAA154]">Trusted &amp; top-rated</p>
      <h2 class="text-[clamp(2rem,4vw,3.25rem)] font-display font-semibold tracking-tight text-[#0a0a0a] mt-5 leading-[1.05]">
        Rated by the world's best <span class="text-[#0a0a0a]/35">review platforms.</span>
      </h2>
    </div>

<style>
  .logo-feedback {
    /* mix-blend-mode: multiply makes the white background of the PNG
       transparent against the cream section background — immersive effect. */
    mix-blend-mode: multiply;
    opacity: 0.9;
  }
</style>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        reviewRatings.map((r, i) => (
          <a
            href={r.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-[1.25rem] border border-black/10 bg-[#ffffff] p-7 shadow-[0_4px_24px_-12px_rgba(0,0,0,0.12)] transition-transform duration-500 hover:-translate-y-1"
            data-reveal
            data-reveal-delay={(i % 3) + 1}
          >
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <img src={r.logo} alt={`${r.firm} Logo`} loading="lazy" decoding="async" class="w-6 h-6 object-contain" />
                <span class="text-lg font-semibold text-[#0a0a0a]">{r.firm}</span>
              </div>
              <span class="text-2xl font-display font-semibold text-[#CAA154]">{r.score}</span>
            </div>
            <div class="mt-3 flex items-center gap-1 text-[#CAA154]" aria-label={`${r.score} out of 5 stars`}>
              {[...Array(5)].map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l2.9 6.26 6.86.6-5.18 4.52 1.55 6.71L12 17.27 5.87 20.6l1.55-6.71L2.24 8.86l6.86-.6z" />
                </svg>
              ))}
            </div>
            <p class="mt-4 text-sm text-black/50">{r.reviews} · <span class="text-black/70 group-hover:text-[#CAA154] transition-colors">View on {r.firm} →</span></p>
          </a>
        ))
      }
    </div>

    {
      pressMentions.length > 0 && (
        <div class="mt-14 flex flex-wrap items-center gap-x-10 gap-y-4 border-t border-black/10 pt-10" data-reveal>
          <span class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-black/40">As featured in</span>
          {pressMentions.map((p) => (
            <span class="text-xl font-display font-semibold text-black/45">{p}</span>
          ))}
        </div>
      )
    }
  </div>
</section>
