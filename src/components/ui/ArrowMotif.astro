---
// Stylized "route arrow" that echoes the Pinnacle Route logo mark.
// Inherits color via currentColor — set opacity/size on the parent class.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 260 300"
  fill="none"
  stroke="currentColor"
  stroke-width="6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <!-- sweeping shaft from lower-left up to the right -->
  <path d="M36 272 C50 168 96 80 214 52" />
  <!-- arrowhead pointing up-right (golden color) -->
  <path d="M156 42 L222 48 L210 116" stroke="var(--color-gold)" />
</svg>
