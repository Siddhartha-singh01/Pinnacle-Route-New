---
/**
 * Preloader
 * ---------
 * A premium full-screen loading animation that runs once per session.
 * Features a minimalistic typographic reveal and smooth upward slide transition.
 */
---

<!-- 
  We use inline styles for the absolute critical initial state to prevent FOUC.
-->
<div id="premium-preloader" transition:persist class="fixed inset-0 z-[9999] bg-[#0a0a0a] flex items-center justify-center overflow-hidden" style="visibility: visible;">
  <div class="preloader-logo-wrapper overflow-hidden">
    <img id="preloader-brand" src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route" class="h-16 md:h-24 w-auto opacity-0 transform translate-y-8" />
  </div>
</div>

<script>
  import { gsap } from "gsap";

  function initPremiumPreloader() {
    const preloader = document.getElementById("premium-preloader");
    const brandText = document.getElementById("preloader-brand");

    if (!preloader || !brandText) return;

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (preloader.classList.contains("is-done") || prefersReducedMotion) {
      preloader.style.display = "none";
      return;
    }

    document.body.style.overflow = "hidden";
    
    const tl = gsap.timeline({
      onComplete: () => {
        document.body.style.overflow = "";
        preloader.style.display = "none";
        preloader.classList.add("is-done");
      }
    });

    tl.to(brandText, {
      y: 0,
      opacity: 1,
      duration: 0.6,
      ease: "power3.out",
      delay: 0.1
    });

    tl.to({}, { duration: 0.5 });

    tl.to(brandText, {
      opacity: 0,
      y: -10,
      duration: 0.4,
      ease: "power2.inOut"
    });

    tl.to(preloader, {
      yPercent: -100,
      duration: 0.8,
      ease: "expo.inOut"
    }, "-=0.2");
  }

  // Use Astro's page-load event which fires on both initial load and view transitions
  document.addEventListener("astro:page-load", initPremiumPreloader);
</script>
