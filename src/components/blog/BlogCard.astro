---
import type { BlogPost } from '@/lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Date formatter
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
};
---

<a href={`/blog/${post.id}`} class="group flex flex-col bg-surface rounded-2xl border border-line-soft overflow-hidden hover:border-line transition-colors">
  
  <!-- Image / Graphic placeholder -->
  <div class="h-48 bg-surface-2 relative flex items-center justify-center p-6">
    <div class="absolute top-4 left-4">
      <span class="px-3 py-1 rounded-full border border-gold/30 bg-ink/50 text-gold text-[0.65rem] font-medium uppercase tracking-wider backdrop-blur-sm">
        {post.data.category}
      </span>
    </div>
    <div class="absolute bottom-4 right-4 text-xs text-grey-2 font-medium bg-ink/80 px-2 py-1 rounded">
      {post.data.readTime} min read
    </div>
    
    <!-- Abstract Icon representation based on category -->
    <div class="w-16 h-16 rounded-2xl bg-ink border border-line-soft flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform duration-500">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold">
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
      </svg>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-1">
    <div class="text-xs text-grey-2 mb-3">{formatDate(post.data.pubDate)}</div>
    <h3 class="text-xl font-display font-medium text-white mb-3 group-hover:text-gold transition-colors line-clamp-2">
      {post.data.title}
    </h3>
    <p class="text-sm text-grey-2 line-clamp-3 mb-6 flex-1">
      {post.data.description}
    </p>
    
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-line-soft">
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-full bg-ink border border-line flex items-center justify-center text-[0.5rem] font-bold text-white">PR</div>
        <span class="text-xs text-grey-2">{post.data.author}</span>
      </div>
      <span class="text-[0.7rem] font-medium tracking-wider text-white uppercase flex items-center gap-1 group-hover:gap-2 transition-all">
        Read <span class="text-gold">→</span>
      </span>
    </div>
  </div>
</a>
