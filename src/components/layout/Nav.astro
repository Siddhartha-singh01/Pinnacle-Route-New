---
/**
 * Nav — Redesigned floating pill navbar
 * Data is imported from @/data/navigation
 */
import { mainMenu } from "@/data/navigation";

const chevron =
  '<svg class="nav-chevron" width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 4.5 6 8l3.5-3.5"/></svg>';

const leftMenu = mainMenu.slice(0, 3);
const rightMenu = mainMenu.slice(3, 7);

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath === href + '/' || currentPath.startsWith(href + '/');
}
---

<header id="site-nav" class="fixed top-0 inset-x-0 z-50 pt-6">
  <div class="container-page flex justify-center">
    <div class="nav-pill flex items-center justify-between w-full max-w-[1200px] bg-ink rounded-[40px] shadow-2xl px-4 sm:px-6 h-[72px] border border-line-soft">
      
      <!-- Left Section: Icons + Links -->
      <div class="flex items-center gap-6">
        <!-- Grid & Search Icons -->
        <div class="hidden lg:flex items-center gap-4 text-gray-400">
          <button id="side-panel-open" onclick="window.openSidePanel && window.openSidePanel()" class="hover:text-white transition-colors" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="7" height="7" rx="1"></rect>
              <rect x="14" y="3" width="7" height="7" rx="1"></rect>
              <rect x="14" y="14" width="7" height="7" rx="1"></rect>
              <rect x="3" y="14" width="7" height="7" rx="1"></rect>
            </svg>
          </button>
          <button id="search-open" class="hover:text-white transition-colors cursor-pointer" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </div>

        <!-- Links -->
        <nav class="hidden lg:flex items-center gap-6 text-[13px] font-medium tracking-wide text-white uppercase" aria-label="Left Primary">
          <a href="/" class="flex items-center justify-center w-10 h-10 bg-white/10 text-white rounded-full hover:bg-white/20 transition-colors" aria-label="Home">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
          </a>
          {
            leftMenu.map((m) =>
              m.items ? (
                <div class="nav-group relative group">
                  <a href={m.href} class={`nav-link py-2 flex items-center gap-1 hover:text-[#CAA154] transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : ''}`}>
                    {m.label}
                    <Fragment set:html={chevron} />
                  </a>
                  <div class="nav-dropdown absolute left-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                    <div class={`bg-white rounded-2xl shadow-xl border border-gray-100 p-2 grid gap-1 ${m.cols === 2 ? "grid-cols-2 min-w-[26rem]" : "min-w-[13rem]"}`}>
                      {m.items.map((it) => (
                        <a href={it.href} class={`block rounded-xl px-4 py-2.5 text-sm transition-colors duration-200 capitalize ${isActive(it.href) ? 'text-[#CAA154] bg-gray-50' : 'text-gray-500 hover:text-[#CAA154] hover:bg-gray-50'}`}>
                          {it.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a href={m.href} class={`nav-link py-2 hover:text-[#CAA154] transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : ''}`}>
                  {m.label}
                </a>
              )
            )
          }
        </nav>
      </div>

      <!-- Center: Logo -->
      <a href="/" class="shrink-0 mx-4" aria-label="Pinnacle Route home">
        <!-- Kept the actual logo for branding consistency -->
        <img src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route" class="h-10 w-auto" />
      </a>

      <!-- Right Section: Links + CTA -->
      <div class="flex items-center gap-6">
        <!-- Links -->
        <nav class="hidden lg:flex items-center gap-6 text-[13px] font-medium tracking-wide text-white uppercase" aria-label="Right Primary">
          {
            rightMenu.map((m) =>
              m.items ? (
                <div class="nav-group relative group">
                  <a href={m.href} class={`nav-link py-2 flex items-center gap-1 hover:text-[#CAA154] transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : ''}`}>
                    {m.label}
                    <Fragment set:html={chevron} />
                  </a>
                  <div class="nav-dropdown absolute left-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                    <div class={`bg-white rounded-2xl shadow-xl border border-gray-100 p-2 grid gap-1 ${m.cols === 2 ? "grid-cols-2 min-w-[26rem]" : "min-w-[13rem]"}`}>
                      {m.items.map((it) => (
                        <a href={it.href} class={`block rounded-xl px-4 py-2.5 text-sm transition-colors duration-200 capitalize ${isActive(it.href) ? 'text-[#CAA154] bg-gray-50' : 'text-gray-500 hover:text-[#CAA154] hover:bg-gray-50'}`}>
                          {it.label}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a href={m.href} class={`nav-link py-2 hover:text-[#CAA154] transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : ''}`}>
                  {m.label}
                </a>
              )
            )
          }
        </nav>

        <!-- CTA -->
        <a href="/strategy-call" class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 rounded-full text-sm font-medium text-black bg-white relative group overflow-hidden">
          <span class="absolute inset-0 rounded-full border-[1.5px] border-transparent [background:linear-gradient(white,white)_padding-box,linear-gradient(to_right,#0052ff,#ff0066)_border-box]"></span>
          <span class="relative z-10 group-hover:scale-105 transition-transform duration-300">Get in touch</span>
        </a>

        <!-- Mobile Menu Toggle -->
        <button id="menu-open" type="button" class="lg:hidden flex flex-col gap-[5px] p-2.5 text-white" aria-label="Open menu">
          <span class="block h-px w-6 bg-current"></span>
          <span class="block h-px w-6 bg-current"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Fullscreen mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-white translate-y-full transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] overflow-y-auto">
  <div class="container-page relative z-10 min-h-full flex flex-col py-6">
    <div class="flex items-center justify-between h-16">
      <img src="/assets/brand/logo.png" alt="Pinnacle Route" class="h-8 w-auto" style="filter: invert(1);" />
      <button id="menu-close" type="button" class="text-gray-500 hover:text-ink text-sm tracking-wide font-medium" aria-label="Close menu">CLOSE ✕</button>
    </div>

    <nav class="flex-1 flex flex-col gap-8 py-10" aria-label="Mobile">
      {
        mainMenu.map((m) => (
          <div>
            <a href={m.href} class={`display-sm !text-3xl uppercase hover:text-[#CAA154] transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : 'text-ink'}`}>{m.label}</a>
            {m.items && (
              <div class="mt-3 grid grid-cols-2 gap-x-6 gap-y-2">
                {m.items.map((it) => (
                  <a href={it.href} class={`text-sm transition-colors py-1 capitalize hover:text-[#CAA154] ${isActive(it.href) ? 'text-[#CAA154]' : 'text-gray-500'}`}>
                    {it.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <a href="/strategy-call" class="inline-flex items-center justify-center px-8 py-4 rounded-full text-lg font-medium text-white bg-ink self-start">
      Get in touch
    </a>
  </div>
</div>
