---
/**
 * Nav — Redesigned floating pill navbar
 * Data is dynamically fetched from Astro DB
 */
import { db, Navigation, ServiceDetails, SolutionDetails } from 'astro:db';

// Fetch base nav links
const navLinks = await db.select().from(Navigation).orderBy(Navigation.orderIndex);

// Fetch dropdown data (include a short description for the mega-menu)
const dbServices = await db.select({ slug: ServiceDetails.slug, label: ServiceDetails.label, intro: ServiceDetails.intro }).from(ServiceDetails);
const dbSolutions = await db.select({ slug: SolutionDetails.slug, label: SolutionDetails.label, tagline: SolutionDetails.tagline }).from(SolutionDetails);

// Reconstruct mainMenu dynamically
const mainMenu = navLinks.map(link => {
  if (link.id === 'nav-solutions') {
    return {
      label: link.label,
      href: link.href,
      cols: 2,
      items: dbSolutions.map(s => ({ label: s.label, href: `/solutions/${s.slug}`, desc: s.tagline }))
    };
  }
  if (link.id === 'nav-services') {
    return {
      label: link.label,
      href: link.href,
      cols: 2,
      items: dbServices.map(s => ({ label: s.label, href: `/services/${s.slug}`, desc: s.intro }))
    };
  }
  return {
    label: link.label,
    href: link.href
  };
});

const chevron =
  '<svg class="nav-chevron" width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 4.5 6 8l3.5-3.5"/></svg>';

const leftMenu = mainMenu.slice(0, 3);
const rightMenu = mainMenu.slice(3, 7);

const currentPath = Astro.url.pathname;

function isActive(target: any) {
  if (!target) return false;
  
  if (typeof target === 'string') {
    if (target === '/') return currentPath === '/';
    return currentPath === target || currentPath === target + '/' || (target !== '/' && currentPath.startsWith(target + '/'));
  }
  
  if (target.href === '/') return currentPath === '/';
  
  const isDirectMatch = target.href && (
    currentPath === target.href || 
    currentPath === target.href + '/' || 
    (target.href !== '/' && currentPath.startsWith(target.href + '/'))
  );
  if (isDirectMatch) return true;

  if (target.items) {
    return target.items.some((sub: any) => 
      currentPath === sub.href || 
      currentPath === sub.href + '/' || 
      currentPath.startsWith(sub.href + '/')
    );
  }

  return false;
}
---

<header id="site-nav" class="fixed top-0 inset-x-0 z-50 pt-6">
  <div class="container-page flex justify-center">
    <div class="nav-pill flex items-center justify-between w-full max-w-[1200px] bg-ink rounded-[40px] shadow-2xl px-4 sm:px-6 h-[72px] border border-line-soft">
      
      <!-- Left Section: Icons + Links -->
      <div class="flex items-center gap-6">
        <!-- Mobile logo — its own black pill on phones (left side) -->
        <a href="/" class="lg:hidden shrink-0 max-sm:flex max-sm:items-center max-sm:h-[60px] max-sm:px-5 max-sm:rounded-full max-sm:bg-[#000000] max-sm:border max-sm:border-[#ffffff1f] max-sm:shadow-[0_24px_60px_-26px_rgba(0,0,0,0.9)]" aria-label="Pinnacle Route home">
          <img src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route" class="h-9 w-auto" />
        </a>

        <!-- Grid & Search Icons -->
        <div class="hidden lg:flex items-center gap-4 text-gray-400">
          <button id="side-panel-open" onclick="window.openSidePanel && window.openSidePanel()" class="hover:text-white transition-colors" aria-label="Menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="7" height="7" rx="1"></rect>
              <rect x="14" y="3" width="7" height="7" rx="1"></rect>
              <rect x="14" y="14" width="7" height="7" rx="1"></rect>
              <rect x="3" y="14" width="7" height="7" rx="1"></rect>
            </svg>
          </button>
          <button id="search-open" class="hover:text-white transition-colors cursor-pointer" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </div>

        <!-- Links -->
        <nav class="hidden lg:flex items-center gap-6 text-[13px] font-medium tracking-wide text-white uppercase" aria-label="Left Primary">
          <a href="/" class={`flex items-center justify-center w-10 h-10 rounded-full nav-home-btn ${isActive('/') ? 'active' : ''}`} aria-label="Home">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
          </a>
          {
            leftMenu.map((m) =>
              m.items ? (
                <div class="nav-group relative group">
                  <a href={m.href} class={`nav-link py-2 flex items-center gap-1 ${isActive(m) ? 'active' : ''}`}>
                    {m.label}
                    <Fragment set:html={chevron} />
                  </a>
                  <div class="nav-dropdown absolute left-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible">
                    <div class="nav-mega grid grid-cols-[1fr_13rem] w-[42rem] max-w-[calc(100vw-2rem)] rounded-2xl bg-[#ffffff] border border-black/[0.06] shadow-[0_30px_70px_-25px_rgba(0,0,0,0.45)] overflow-hidden">
                      <div class="p-3 grid grid-cols-2 gap-1">
                        {m.items.map((it) => (
                          <a href={it.href} class={`group/i flex items-start gap-3 rounded-xl p-3 transition-colors ${isActive(it.href) ? 'bg-[#faf7f0]' : 'hover:bg-[#faf7f0]'}`}>
                            <span class="mt-0.5 grid place-items-center h-9 w-9 rounded-lg bg-[#CAA154]/12 text-[#CAA154] shrink-0">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
                            </span>
                            <span class="min-w-0 normal-case">
                              <span class={`block text-sm font-semibold ${isActive(it.href) ? 'text-[#CAA154]' : 'text-[#0a0a0a] group-hover/i:text-[#CAA154]'} transition-colors`}>{it.label}</span>
                              {it.desc && <span class="block text-xs leading-snug mt-0.5 text-black/45 line-clamp-2">{it.desc}</span>}
                            </span>
                          </a>
                        ))}
                      </div>
                      <a href={m.href} class="relative flex flex-col justify-between overflow-hidden bg-[#0a0a0a] p-6 normal-case">
                        <span class="pointer-events-none absolute -right-6 -top-6 h-24 w-24 rounded-full bg-[#CAA154]/25 blur-2xl"></span>
                        <span class="relative">
                          <span class="block text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[#CAA154]">{m.label}</span>
                          <span class="mt-3 block text-lg font-display leading-snug text-[#ffffff]">Explore all {m.label.toLowerCase()}</span>
                        </span>
                        <span class="relative mt-6 inline-flex items-center gap-2 text-sm font-medium text-[#ffffff]/90">View all <span aria-hidden="true">→</span></span>
                      </a>
                    </div>
                  </div>
                </div>
              ) : (
                <a href={m.href} class={`nav-link py-2 ${isActive(m) ? 'active' : ''}`}>
                  {m.label}
                </a>
              )
            )
          }
        </nav>
      </div>

      <!-- Center: Logo (desktop only — mobile uses the left-aligned logo above) -->
      <a href="/" class="hidden lg:block shrink-0 mx-4" aria-label="Pinnacle Route home">
        <!-- Kept the actual logo for branding consistency -->
        <img src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route" class="h-10 w-auto" />
      </a>

      <!-- Right Section: Links + CTA -->
      <div class="flex items-center gap-6">
        <!-- Links -->
        <nav class="hidden lg:flex items-center gap-6 text-[13px] font-medium tracking-wide text-white uppercase" aria-label="Right Primary">
          {
            rightMenu.map((m) =>
              m.items ? (
                <div class="nav-group relative group">
                  <a href={m.href} class={`nav-link py-2 flex items-center gap-1 ${isActive(m) ? 'active' : ''}`}>
                    {m.label}
                    <Fragment set:html={chevron} />
                  </a>
                  <div class="nav-dropdown absolute right-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible">
                    <div class="nav-mega grid grid-cols-[1fr_13rem] w-[42rem] max-w-[calc(100vw-2rem)] rounded-2xl bg-[#ffffff] border border-black/[0.06] shadow-[0_30px_70px_-25px_rgba(0,0,0,0.45)] overflow-hidden">
                      <div class="p-3 grid grid-cols-2 gap-1">
                        {m.items.map((it) => (
                          <a href={it.href} class={`group/i flex items-start gap-3 rounded-xl p-3 transition-colors ${isActive(it.href) ? 'bg-[#faf7f0]' : 'hover:bg-[#faf7f0]'}`}>
                            <span class="mt-0.5 grid place-items-center h-9 w-9 rounded-lg bg-[#CAA154]/12 text-[#CAA154] shrink-0">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
                            </span>
                            <span class="min-w-0 normal-case">
                              <span class={`block text-sm font-semibold ${isActive(it.href) ? 'text-[#CAA154]' : 'text-[#0a0a0a] group-hover/i:text-[#CAA154]'} transition-colors`}>{it.label}</span>
                              {it.desc && <span class="block text-xs leading-snug mt-0.5 text-black/45 line-clamp-2">{it.desc}</span>}
                            </span>
                          </a>
                        ))}
                      </div>
                      <a href={m.href} class="relative flex flex-col justify-between overflow-hidden bg-[#0a0a0a] p-6 normal-case">
                        <span class="pointer-events-none absolute -right-6 -top-6 h-24 w-24 rounded-full bg-[#CAA154]/25 blur-2xl"></span>
                        <span class="relative">
                          <span class="block text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[#CAA154]">{m.label}</span>
                          <span class="mt-3 block text-lg font-display leading-snug text-[#ffffff]">Explore all {m.label.toLowerCase()}</span>
                        </span>
                        <span class="relative mt-6 inline-flex items-center gap-2 text-sm font-medium text-[#ffffff]/90">View all <span aria-hidden="true">→</span></span>
                      </a>
                    </div>
                  </div>
                </div>
              ) : (
                <a href={m.href} class={`nav-link py-2 ${isActive(m) ? 'active' : ''}`}>
                  {m.label}
                </a>
              )
            )
          }
        </nav>

        <!-- CTA -->
        <a href="/strategy-call" class="hidden sm:inline-flex items-center justify-center px-6 py-2.5 rounded-full text-sm font-medium text-black bg-white relative group overflow-hidden">
          <span class="absolute inset-0 rounded-full border-[1.5px] border-transparent [background:linear-gradient(white,white)_padding-box,linear-gradient(to_right,#0052ff,#ff0066)_border-box]"></span>
          <span class="relative z-10 group-hover:scale-105 transition-transform duration-300">Get in touch</span>
        </a>

        <!-- Mobile Menu Toggle -->
        <button id="menu-open" type="button" class="lg:hidden grid place-items-center w-11 h-11 rounded-full bg-[#ffffff14] border border-[#ffffff1f] text-[#ffffff] transition-colors hover:bg-[#ffffff2e] max-sm:w-[60px] max-sm:h-[60px] max-sm:bg-[#000000] max-sm:border-[#ffffff1f] max-sm:shadow-[0_24px_60px_-26px_rgba(0,0,0,0.9)]" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Fullscreen mobile menu (fixed colors — independent of the page light/dark theme) -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#ffffff] translate-y-full transition-transform duration-700 [transition-timing-function:var(--ease-out-expo)] flex flex-col" aria-hidden="true">
  <!-- Header -->
  <div class="flex items-center justify-between px-6 h-20 border-b border-black/10 shrink-0">
    <a href="/" class="shrink-0 flex items-center gap-2" aria-label="Pinnacle Route home">
      <img src="/assets/brand/logo-gold-transparent.png" alt="Pinnacle Route" class="h-9 w-auto" />
      <span class="font-display font-semibold tracking-tight text-lg text-[#0a0a0a]">Pinnacle Route</span>
    </a>
    <button id="menu-close" type="button" class="grid place-items-center w-11 h-11 rounded-full border border-black/15 text-[#0a0a0a] hover:bg-[#0a0a0a] hover:text-white transition-colors" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>

  <!-- Nav list -->
  <nav class="flex-1 overflow-y-auto px-6" aria-label="Mobile">
    {
      mainMenu.map((m) =>
        m.items ? (
          <div class="mobile-acc border-b border-black/10">
            <button type="button" class="mobile-acc-toggle w-full flex items-center justify-between py-5 text-left" aria-expanded="false">
              <span class={`text-xl font-medium transition-colors ${isActive(m) ? 'text-[#CAA154]' : 'text-[#0a0a0a]'}`}>{m.label}</span>
              <svg class="mobile-acc-chev text-black/40 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="mobile-acc-panel">
              <div class="pb-5 grid grid-cols-1 gap-0.5">
                {m.items.map((it) => (
                  <a href={it.href} class={`flex items-center gap-3 py-2.5 capitalize transition-colors ${isActive(it.href) ? 'text-[#CAA154]' : 'text-black/55 hover:text-[#CAA154]'}`}>
                    <span class="h-px w-4 bg-current opacity-40"></span>
                    {it.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={m.href} class="flex items-center justify-between py-5 border-b border-black/10 group">
            <span class={`text-xl font-medium transition-colors ${isActive(m.href) ? 'text-[#CAA154]' : 'text-[#0a0a0a] group-hover:text-[#CAA154]'}`}>{m.label}</span>
            <svg class="text-black/25 group-hover:text-[#CAA154] transition-all duration-300 group-hover:translate-x-1 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
          </a>
        )
      )
    }
  </nav>

  <!-- Footer -->
  <div class="shrink-0 px-6 py-6 border-t border-black/10 bg-[#f4f3ef]">
    <a href="/strategy-call" class="flex items-center justify-center w-full px-6 py-4 rounded-full text-base font-medium text-[#ffffff] bg-[#0a0a0a] hover:bg-[#CAA154] transition-colors">
      Get in touch
    </a>
    <div class="mt-5 flex items-center justify-between text-sm">
      <a href="tel:+919621391943" class="text-black/60 hover:text-[#CAA154] transition-colors">+91 96213 91943</a>
      <a href="mailto:info@pinnacleroute.com" class="text-black/60 hover:text-[#CAA154] transition-colors">info@pinnacleroute.com</a>
    </div>
  </div>
</div>
