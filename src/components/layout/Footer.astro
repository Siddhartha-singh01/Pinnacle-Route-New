---
/**
 * Footer — 5-column layout with giant watermark, link columns, socials, and back-to-top.
 * Data is dynamically fetched from Astro DB.
 * Back-to-top script is handled by @/scripts/index.ts.
 */
import { db, ServiceDetails, SolutionDetails } from 'astro:db';

const dbServices = await db.select({ slug: ServiceDetails.slug, label: ServiceDetails.label }).from(ServiceDetails);
const dbSolutions = await db.select({ slug: SolutionDetails.slug, label: SolutionDetails.label }).from(SolutionDetails);

const footerColumns = [
  {
    title: "Pinnacle Route",
    links: [
      { label: "Our Work", href: "/#work" },
      { label: "Our Expertise", href: "/our-expertise" },
      { label: "About Us", href: "/our-company" },
      { label: "FAQ", href: "/faq" },
      { label: "Privacy Policy", href: "/privacy-policy/" },
      { label: "Referral", href: "/referral" },
      { label: "Strategy Call", href: "/strategy-call" },
    ],
  },
  {
    title: "Services",
    links: dbServices.map((s) => ({ label: s.label, href: `/services/${s.slug}` })),
  },
  {
    title: "Solutions",
    links: dbSolutions.map((s) => ({ label: s.label, href: `/solutions/${s.slug}` })),
  },
  {
    title: "Contact",
    links: [
      { label: "Media: info@pinnacleroute.com", href: "mailto:info@pinnacleroute.com" },
      { label: "Careers: careers@pinnacleroute.com", href: "mailto:careers@pinnacleroute.com" },
      { label: "Sales: sales@pinnacleroute.com", href: "mailto:sales@pinnacleroute.com" },
    ],
  },
];

const socials = [
  { label: "WhatsApp", href: "https://api.whatsapp.com/send/?phone=919621391943&text=Hi+Pinnacle+Route%2C+I+would+like+to+book+a+free+strategy+session.&type=phone_number&app_absent=0" },
  { label: "LinkedIn", href: "https://www.linkedin.com/company/pinnacle-route" },
  { label: "Twitter / X", href: "https://x.com/PinnacleRoute" },
  { label: "Instagram", href: "https://www.instagram.com/pinnacle_route/" },
  { label: "Threads", href: "https://www.threads.net/@pinnacle_route" },
];

const year = new Date().getFullYear();
---

<footer class="theme-dark relative overflow-hidden bg-ink border-t border-line-soft">
  <!-- giant watermark -->
  <div class="container-page relative z-10 pt-16 sm:pt-20 text-center">
    <h2 class="footer-mark"><span>Pinnacle</span><span class="gold">Route</span></h2>
  </div>

  <!-- columns -->
  <div class="container-page relative z-10 pt-12 pb-14">
    <div class="grid grid-cols-2 gap-x-8 gap-y-10 md:grid-cols-3 lg:grid-cols-5">
      {
        footerColumns.map((col) => (
          <div>
            <h4 class="text-sm font-medium text-white mb-5">
              {col.title === "Pinnacle Route" ? (
                <img src="/assets/brand/logo-full.png" alt="Pinnacle Route" class="h-8 w-auto block" />
              ) : (
                col.title
              )}
            </h4>
            <ul class="space-y-3 border-t border-line-soft pt-5">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="text-[0.95rem] text-grey-2 hover:text-gold transition-colors duration-300">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div>
        <h4 class="text-sm font-medium text-white mb-5">Socials</h4>
        <ul class="space-y-3 border-t border-line-soft pt-5">
          {
            socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener" class="group inline-flex items-center gap-1.5 text-[0.95rem] text-grey-2 hover:text-gold transition-colors duration-300">
                  {s.label}
                  <span class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- bottom bar -->
  <div class="container-page relative z-10 py-8 border-t border-line-soft flex items-center justify-between text-sm text-grey-3">
    <p>© {year} Pinnacle <span class="text-gold">Route</span></p>
    <button id="back-to-top" type="button" class="inline-flex items-center gap-2 hover:text-gold transition-colors duration-300">
      <span>↑</span> Back to top
    </button>
  </div>
</footer>
